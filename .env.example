# --- Recipe web search (Google Programmable Search / Custom Search JSON API) ---
# Create a Programmable Search Engine and enable the Custom Search API in Google Cloud.
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_ID=

# Optional: comma-separated domains (default includes Bon Appétit, Ricardo, Serious Eats, Food Network)
# RECIPE_SEARCH_SITES=bonappetit.com,ricardocuisine.com

# Optional: max trusted recipe URLs to fetch + normalize per search (default 4, hard cap 5)
# RECIPE_NORMALIZE_MAX_PAGES=4

# Optional: max time (ms) per AI normalizeObject call — avoids hung Ollama (default 30000, max 300000)
# RECIPE_AI_TIMEOUT_MS=30000

# --- AI normalization for web-grounded recipes (pick one stack) ---
# Local dev: Ollama is tried first (no gateway cost). Comment these out on Vercel
# and set VERCEL_* below so production uses the AI Gateway.
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=mistral:latest
# OLLAMA_API_KEY=ollama

# Hosted: Vercel AI Gateway (use when OLLAMA_BASE_URL is unset)
# VERCEL_AI_GATEWAY_API_KEY=   # or use VERCEL_VIRTUAL_KEY (same role)
# VERCEL_VIRTUAL_KEY=
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
# AI_GATEWAY_MODEL=openai/gpt-4o-mini

# Fallback: OpenAI API directly
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
